{
  "name": "@mrbagels/dossier",
  "version": "0.5.1",
  "description": "Generate polished, self-contained, agent-readable HTML briefs (plus Markdown) from a single JSON document model. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "dossier": "./bin/dossier.mjs"
  },
  "exports": {
    ".": "./src/index.mjs",
    "./schema": "./schema/dossier.schema.json"
  },
  "files": [
    "bin",
    "src",
    "schema",
    "mcp",
    "skill",
    "examples/*.dossier.json",
    "examples/plugins",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node bin/dossier.mjs build examples/*.json",
    "example": "node bin/dossier.mjs build examples/sample.dossier.json",
    "test": "node --test",
    "serve": "node bin/dossier.mjs serve",
    "site": "node scripts/build-site.mjs",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "documentation",
    "html",
    "markdown",
    "agent",
    "llm",
    "static",
    "brief"
  ],
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "^1.22.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "docx": "^9.7.1",
    "image-size": "^2.0.2",
    "katex": "^0.17.0",
    "shiki": "^4.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "mermaid": "^11.16.0",
    "playwright": "^1.61.1"
  }
}
