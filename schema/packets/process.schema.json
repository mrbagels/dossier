{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mrbagels/dossier/schema/packets/process.schema.json",
  "title": "Dossier Process Packet",
  "type": "object",
  "required": ["schema", "process"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "dossier.process/v1" },
    "slug": { "type": "string" },
    "process": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/processEntry" }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/processEntryWithId" }
    }
  },
  "$defs": {
    "verdict": { "type": "string", "enum": ["undecided", "approve", "revise", "skip", "defer", "split", "retry", "block"] },
    "processEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "verdict": { "$ref": "#/$defs/verdict" },
        "notes": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "processEntryWithId": {
      "allOf": [
        { "$ref": "#/$defs/processEntry" },
        { "type": "object", "required": ["id"], "properties": { "id": { "type": "string", "pattern": "^[a-z0-9-]+$" } } }
      ]
    }
  }
}
