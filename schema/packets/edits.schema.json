{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mrbagels/dossier/schema/packets/edits.schema.json",
  "title": "Dossier Edits Packet",
  "type": "object",
  "required": ["schema", "edits"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "dossier.edits/v1" },
    "slug": { "type": "string" },
    "edits": { "type": "object", "additionalProperties": { "$ref": "#/$defs/edit" } },
    "items": { "type": "array", "items": { "$ref": "#/$defs/editWithId" } }
  },
  "$defs": {
    "edit": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": true,
      "properties": {
        "text": { "type": "string" },
        "lang": { "type": "string" },
        "filename": { "type": "string" },
        "targetPath": { "type": "string" },
        "title": { "type": "string" },
        "dirty": { "type": "boolean" }
      }
    },
    "editWithId": {
      "allOf": [
        { "$ref": "#/$defs/edit" },
        { "type": "object", "required": ["id"], "properties": { "id": { "type": "string" } } }
      ]
    }
  }
}
