{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kylebegeman/dossier/schema/packets/diff-review.schema.json",
  "title": "Dossier Diff Review Packet",
  "type": "object",
  "required": ["schema", "files", "hunks"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "dossier.diff-review/v1" },
    "slug": { "type": "string" },
    "files": { "type": "object", "additionalProperties": { "$ref": "#/$defs/review" } },
    "hunks": { "type": "object", "additionalProperties": { "$ref": "#/$defs/review" } }
  },
  "$defs": {
    "verdict": { "type": "string", "enum": ["undecided", "approve", "revise", "skip", "defer", "block"] },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "verdict": { "$ref": "#/$defs/verdict" },
        "comment": { "type": "string" }
      }
    }
  }
}
