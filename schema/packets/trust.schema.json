{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dossier Trust Packet",
  "type": "object",
  "required": ["schema"],
  "properties": {
    "schema": {
      "const": "dossier.trust/v1"
    },
    "slug": {
      "type": "string"
    },
    "reports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/report"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      },
      "description": "Convenience form for a single report."
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      },
      "description": "Convenience form for a single report."
    }
  },
  "$defs": {
    "report": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "trust": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "created": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "claim": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "claim": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
