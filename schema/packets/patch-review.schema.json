{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kylebegeman/dossier/schema/packets/patch-review.schema.json",
  "title": "Dossier Patch Review Packet",
  "type": "object",
  "required": ["schema", "patches"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "dossier.patch-review/v1" },
    "slug": { "type": "string" },
    "patches": { "type": "object", "additionalProperties": { "$ref": "#/$defs/review" } },
    "items": { "type": "array", "items": { "$ref": "#/$defs/reviewWithId" } }
  },
  "$defs": {
    "verdict": { "type": "string", "enum": ["undecided", "approve", "revise", "skip", "defer", "block"] },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "verdict": { "$ref": "#/$defs/verdict" },
        "notes": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "reviewWithId": {
      "allOf": [
        { "$ref": "#/$defs/review" },
        { "type": "object", "required": ["id"], "properties": { "id": { "type": "string" } } }
      ]
    }
  }
}
