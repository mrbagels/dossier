{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mrbagels/dossier/schema/packets/release.schema.json",
  "title": "Dossier Release Packet",
  "type": "object",
  "required": ["schema", "release"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "dossier.release/v1" },
    "slug": { "type": "string" },
    "release": { "type": "object", "additionalProperties": { "$ref": "#/$defs/gate" } },
    "gates": { "type": "array", "items": { "$ref": "#/$defs/gateWithId" } }
  },
  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "done": { "type": "boolean" },
        "notes": { "type": "string" },
        "title": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "gateWithId": {
      "allOf": [
        { "$ref": "#/$defs/gate" },
        { "type": "object", "required": ["id"], "properties": { "id": { "type": "string", "pattern": "^[a-z0-9-]+$" } } }
      ]
    }
  }
}
