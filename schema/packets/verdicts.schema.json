{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kylebegeman/dossier/schema/packets/verdicts.schema.json",
  "title": "Dossier Verdicts Packet",
  "type": "object",
  "required": ["schema", "verdicts"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "dossier.verdicts/v1" },
    "slug": { "type": "string" },
    "verdicts": { "type": "object", "additionalProperties": { "$ref": "#/$defs/verdictEntry" } },
    "items": { "type": "array", "items": { "$ref": "#/$defs/verdictEntryWithId" } }
  },
  "$defs": {
    "verdict": { "type": "string", "enum": ["undecided", "approve", "revise", "skip", "defer", "split", "retry", "block"] },
    "verdictEntry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "verdict": { "$ref": "#/$defs/verdict" },
        "notes": { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "verdictEntryWithId": {
      "allOf": [
        { "$ref": "#/$defs/verdictEntry" },
        { "type": "object", "required": ["id"], "properties": { "id": { "type": "string" } } }
      ]
    }
  }
}
