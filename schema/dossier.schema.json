{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mrbagels/dossier",
  "title": "Dossier Document Model",
  "description": "The single JSON contract an agent fills to generate a Dossier. The rendered HTML is a projection of this object, which is embedded back into the output as the source-of-truth data island (#dossier-model).",
  "type": "object",
  "required": [
    "dossierVersion",
    "meta",
    "blocks"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference for editor autocomplete."
    },
    "dossierVersion": {
      "description": "Schema contract version this document targets.",
      "type": "string",
      "const": "1.0"
    },
    "schema": {
      "description": "Schema namespace identifier.",
      "type": "string",
      "default": "dossier/v1"
    },
    "kind": {
      "description": "Document preset. Selects default block order, chrome, and which features are enabled.",
      "type": "string",
      "enum": [
        "reader",
        "review-board",
        "dossier",
        "adr",
        "runbook",
        "research",
        "comparison"
      ],
      "default": "dossier"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "blocks": {
      "description": "Ordered list of content blocks. Rendered top to bottom.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/block"
      }
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": [
        "title"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "slug": {
          "type": "string",
          "description": "Stable id for cross-artifact links and filenames.",
          "pattern": "^[a-z0-9-]+$"
        },
        "eyebrow": {
          "type": "string",
          "description": "Short kicker above the title."
        },
        "lede": {
          "type": "string",
          "description": "One or two sentence summary under the title."
        },
        "crumbs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Breadcrumb trail."
        },
        "status": {
          "type": "string",
          "enum": [
            "scratchpad",
            "draft",
            "review",
            "durable",
            "archived"
          ],
          "default": "draft"
        },
        "owner": {
          "type": "string"
        },
        "project": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "version": {
          "type": "string",
          "description": "Human document version, e.g. 1.2.0."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "baseUrl": {
          "type": "string",
          "description": "Absolute base URL for cross-artifact [[slug]] links when hosted. Omit to use relative file links."
        },
        "theme": {
          "type": "object",
          "description": "Per-project design token overrides (CSS custom property values without the --ds- prefix).",
          "additionalProperties": {
            "type": "string"
          }
        },
        "features": {
          "type": "object",
          "description": "Toggle optional runtime features. Defaults come from `kind`. Set false to disable.",
          "additionalProperties": false,
          "properties": {
            "toc": {
              "type": "boolean"
            },
            "readingProgress": {
              "type": "boolean"
            },
            "search": {
              "type": "boolean"
            },
            "commandPalette": {
              "type": "boolean"
            },
            "collapsible": {
              "type": "boolean"
            },
            "blockCopy": {
              "type": "boolean"
            },
            "agentDigest": {
              "type": "boolean"
            },
            "crossLinks": {
              "type": "boolean"
            },
            "review": {
              "type": "boolean",
              "description": "Annotation + approve/reject + import-JSON round-trip."
            },
            "lifecycleBanner": {
              "type": "boolean"
            }
          }
        },
        "lifecycle": {
          "type": "object",
          "description": "Drives the lifecycle banner (feature 22).",
          "additionalProperties": false,
          "properties": {
            "stage": {
              "type": "string",
              "enum": [
                "scratchpad",
                "review",
                "durable"
              ]
            },
            "note": {
              "type": "string"
            },
            "promoteTo": {
              "type": "string"
            }
          }
        },
        "changelog": {
          "description": "Version history (feature 15). The generator can diff the embedded model against a prior version's JSON.",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "version"
            ],
            "additionalProperties": false,
            "properties": {
              "version": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "format": "date"
              },
              "summary": {
                "type": "string"
              },
              "changes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "blockBase": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable id used for deep links, data-id, and machine addressing. Auto-derived from headings when omitted."
        },
        "type": {
          "type": "string"
        },
        "copyable": {
          "type": "boolean",
          "description": "Show a per-block copy control (feature 7). Defaults true for most blocks.",
          "default": true
        },
        "collapsed": {
          "type": "boolean",
          "description": "Initial collapsed state (feature 5)."
        }
      }
    },
    "block": {
      "description": "A content block. Discriminated by `type`.",
      "oneOf": [
        {
          "$ref": "#/$defs/blocks/hero"
        },
        {
          "$ref": "#/$defs/blocks/prose"
        },
        {
          "$ref": "#/$defs/blocks/section"
        },
        {
          "$ref": "#/$defs/blocks/twoCol"
        },
        {
          "$ref": "#/$defs/blocks/summaryCards"
        },
        {
          "$ref": "#/$defs/blocks/statStrip"
        },
        {
          "$ref": "#/$defs/blocks/flow"
        },
        {
          "$ref": "#/$defs/blocks/timeline"
        },
        {
          "$ref": "#/$defs/blocks/table"
        },
        {
          "$ref": "#/$defs/blocks/callout"
        },
        {
          "$ref": "#/$defs/blocks/code"
        },
        {
          "$ref": "#/$defs/blocks/tabs"
        },
        {
          "$ref": "#/$defs/blocks/faq"
        },
        {
          "$ref": "#/$defs/blocks/references"
        },
        {
          "$ref": "#/$defs/blocks/decisionMatrix"
        },
        {
          "$ref": "#/$defs/blocks/riskRegister"
        },
        {
          "$ref": "#/$defs/blocks/actionItems"
        },
        {
          "$ref": "#/$defs/blocks/assumptions"
        },
        {
          "$ref": "#/$defs/blocks/glossary"
        },
        {
          "$ref": "#/$defs/blocks/diagram"
        },
        {
          "$ref": "#/$defs/blocks/reviewBoard"
        }
      ]
    },
    "blocks": {
      "hero": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "const": "hero"
          },
          "eyebrow": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "lede": {
            "type": "string"
          },
          "pills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sideCards": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "label",
                "value"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                },
                "note": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "prose": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "markdown"
        ],
        "properties": {
          "type": {
            "const": "prose"
          },
          "heading": {
            "type": "string"
          },
          "markdown": {
            "type": "string",
            "description": "Inline-Markdown rich text. Supports [[slug]] cross-links and [[term]] glossary refs."
          }
        }
      },
      "section": {
        "description": "A titled container. May frame its children or render unframed.",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "title"
        ],
        "properties": {
          "type": {
            "const": "section"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "framed": {
            "type": "boolean",
            "default": true
          },
          "blocks": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/block"
            }
          }
        }
      },
      "twoCol": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "left",
          "right"
        ],
        "properties": {
          "type": {
            "const": "two-col"
          },
          "left": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/block"
            }
          },
          "right": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/block"
            }
          }
        }
      },
      "summaryCards": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "cards"
        ],
        "properties": {
          "type": {
            "const": "summary-cards"
          },
          "cards": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "body"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                },
                "tone": {
                  "type": "string",
                  "enum": [
                    "neutral",
                    "accent",
                    "highlight",
                    "success",
                    "warning",
                    "danger"
                  ]
                }
              }
            }
          }
        }
      },
      "statStrip": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "stats"
        ],
        "properties": {
          "type": {
            "const": "stat-strip"
          },
          "stats": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "value",
                "label"
              ],
              "properties": {
                "value": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "flow": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "steps"
        ],
        "properties": {
          "type": {
            "const": "flow"
          },
          "title": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title",
                "body"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "timeline": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "phases"
        ],
        "properties": {
          "type": {
            "const": "timeline"
          },
          "title": {
            "type": "string"
          },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "label",
                "body"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "done",
                    "in-progress",
                    "planned",
                    "blocked"
                  ]
                },
                "date": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "table": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "columns",
          "rows"
        ],
        "properties": {
          "type": {
            "const": "table"
          },
          "title": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "callout": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "body"
        ],
        "properties": {
          "type": {
            "const": "callout"
          },
          "tone": {
            "type": "string",
            "enum": [
              "info",
              "ok",
              "warn",
              "danger",
              "tip"
            ],
            "default": "info"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        }
      },
      "code": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "code"
        ],
        "properties": {
          "type": {
            "const": "code"
          },
          "lang": {
            "type": "string",
            "description": "Language label + syntax highlight hint (feature 24)."
          },
          "filename": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "tabs": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "tabs"
        ],
        "properties": {
          "type": {
            "const": "tabs"
          },
          "tabs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "label",
                "blocks"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "blocks": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/block"
                  }
                }
              }
            }
          }
        }
      },
      "faq": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "items"
        ],
        "properties": {
          "type": {
            "const": "faq"
          },
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "q",
                "a"
              ],
              "properties": {
                "q": {
                  "type": "string"
                },
                "a": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "references": {
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "items"
        ],
        "properties": {
          "type": {
            "const": "references"
          },
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "label"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "signal": {
                  "type": "string",
                  "description": "Why this source matters."
                },
                "use": {
                  "type": "string",
                  "description": "How it should be used."
                }
              }
            }
          }
        }
      },
      "decisionMatrix": {
        "description": "Static options-vs-criteria comparison (display only; interactive scoring not included).",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "options",
          "criteria"
        ],
        "properties": {
          "type": {
            "const": "decision-matrix"
          },
          "title": {
            "type": "string"
          },
          "criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "scores"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "scores": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "One cell per criterion, in order."
                },
                "recommended": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "riskRegister": {
        "description": "Static risk table (display only; interactive filtering not included).",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "risks"
        ],
        "properties": {
          "type": {
            "const": "risk-register"
          },
          "title": {
            "type": "string"
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "risk"
              ],
              "properties": {
                "risk": {
                  "type": "string"
                },
                "likelihood": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "impact": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "mitigation": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "actionItems": {
        "description": "Interactive checklist (feature 18). State persists locally and exports.",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "items"
        ],
        "properties": {
          "type": {
            "const": "action-items"
          },
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "title"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "owner": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "todo",
                    "doing",
                    "done",
                    "blocked"
                  ],
                  "default": "todo"
                },
                "note": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "assumptions": {
        "description": "Assumptions and open questions register (feature 14).",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "items"
        ],
        "properties": {
          "type": {
            "const": "assumptions"
          },
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "statement"
              ],
              "properties": {
                "statement": {
                  "type": "string"
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "assumption",
                    "open-question"
                  ],
                  "default": "assumption"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "unverified",
                    "verified",
                    "rejected"
                  ],
                  "default": "unverified"
                }
              }
            }
          }
        }
      },
      "glossary": {
        "description": "Term definitions; [[term]] references elsewhere resolve to hover tooltips (feature 25).",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "terms"
        ],
        "properties": {
          "type": {
            "const": "glossary"
          },
          "title": {
            "type": "string"
          },
          "terms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "term",
                "definition"
              ],
              "properties": {
                "term": {
                  "type": "string"
                },
                "definition": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "diagram": {
        "description": "Diagram baked to static inline SVG at generate time (feature 23).",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "spec"
        ],
        "properties": {
          "type": {
            "const": "diagram"
          },
          "title": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": [
              "mermaid"
            ],
            "default": "mermaid"
          },
          "spec": {
            "type": "string",
            "description": "Diagram source (e.g. Mermaid)."
          }
        }
      },
      "reviewBoard": {
        "description": "Interactive decision surface (features 16/17/21): selectable candidate cards with notes, verdicts, and JSON round-trip.",
        "allOf": [
          {
            "$ref": "#/$defs/blockBase"
          }
        ],
        "required": [
          "type",
          "candidates"
        ],
        "properties": {
          "type": {
            "const": "review-board"
          },
          "title": {
            "type": "string"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional grouping labels for filtering."
          },
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "title",
                "summary"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "title": {
