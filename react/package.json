{
  "name": "@dossier/react",
  "version": "0.2.2",
  "type": "module",
  "description": "React/TSX components for Dossier. Renders the same self-contained design via SSR, reusing the core design system, runtime, and build-time enrichment.",
  "scripts": {
    "example": "tsx src/cli.tsx ../examples/sample.dossier.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "motion": "^12.42.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  }
}
